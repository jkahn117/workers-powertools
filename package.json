{
  "name": "workers-powertools",
  "private": true,
  "description": "A developer toolkit for observability and reliability best practices for Cloudflare Workers",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "build": "turbo run build --filter=./packages/*",
    "size": "node scripts/check-size.mjs",
    "test": "turbo run test --filter=./packages/*",
    "lint": "turbo run lint --filter=./packages/*",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\"",
    "typecheck": "turbo run typecheck --filter=./packages/*",
    "clean": "turbo run clean --filter=./packages/*",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "check-exports": "node scripts/check-exports.mjs",
    "release": "turbo run build && node scripts/check-exports.mjs && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@cloudflare/workers-types": "^4.20260505.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js-pure",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
