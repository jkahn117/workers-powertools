{
  "name": "@workers-powertools/agents",
  "version": "0.1.1",
  "description": "Cloudflare Agents SDK integration for Workers Powertools — instrumentation for Agent RPC methods, DO lifecycle, and WebSocket connections",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "@workers-powertools/logger": ">=0.1.1",
    "@workers-powertools/tracer": ">=0.1.1",
    "agents": ">=0.10.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@workers-powertools/logger": "workspace:*",
    "@workers-powertools/tracer": "workspace:*",
    "agents": "^0.10.0"
  }
}
