{
  "name": "@workers-powertools/metrics",
  "version": "0.3.1",
  "description": "Named business metrics for Cloudflare Workers — Pipelines backend (default) or Analytics Engine (opt-in)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pipelines": {
      "types": "./dist/pipelines.d.ts",
      "import": "./dist/pipelines.js"
    },
    "./analytics-engine": {
      "types": "./dist/analyticsEngine.d.ts",
      "import": "./dist/analyticsEngine.js"
    }
  },
  "files": [
    "dist",
    "schema.json",
    "PIPELINES_SETUP.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@workers-powertools/commons": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:"
  }
}
