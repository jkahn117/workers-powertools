{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],

    /* TC39 Stage 3 decorators — experimentalDecorators: false is required.
       With target ES2022, esbuild/wrangler lowers decorator syntax rather
       than passing it through to the runtime. */
    "experimentalDecorators": false,
    "emitDecoratorMetadata": false,

    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["test"],
  "include": ["worker-configuration.d.ts", "src/**/*.ts"]
}
